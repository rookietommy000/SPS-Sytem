# ============================================================
# 備品管理系統 (SPS) 環境變數範本
# 複製此檔為 .env 並填入實際值，.env 不可進入版本控制
# ============================================================

# --- 資料庫 ---
POSTGRES_DB=sps
POSTGRES_USER=sps_user
POSTGRES_PASSWORD=change_this_password

# Prisma 連線字串（後端使用）
DATABASE_URL=postgresql://sps_user:change_this_password@localhost:5432/sps

# --- 後端 ---
NODE_ENV=development
PORT=3000
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=8h

# --- 前端（開發時的 API 位址）---
VITE_API_BASE_URL=http://localhost:3000/api/v1
